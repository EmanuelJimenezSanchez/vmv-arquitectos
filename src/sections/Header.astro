---
import logoVmv from '@/assets/svg/logo-vmv.svg'
import Button from '@/components/ui/Button.astro'
---

<header
  id="site-header"
  class="group fixed inset-x-0 top-0 z-50 w-full transition-transform duration-500"
>
  <div
    class="header-shell w-full animate-[headerReveal_0.8s_cubic-bezier(0.19,1,0.22,1)_both] border border-transparent bg-transparent px-4 py-3 transition-[border-color,background-color,box-shadow] duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] md:px-8 md:py-4"
  >
    <div class="flex min-h-14 items-center justify-start sm:justify-center md:min-h-18">
      <a href="/" class="logo-link shrink-0" aria-label="Inicio VMV Arquitectos">
        <img
          src={logoVmv.src}
          alt="VMV Arquitectos"
          class="h-16 w-auto md:h-20 lg:h-24"
          loading="eager"
        />
      </a>
    </div>
  </div>

  <nav
    class="top-left fixed top-4 left-4 z-60 hidden items-center gap-8 md:top-6 md:left-8 md:flex"
    aria-label="Navegación principal"
  >
    <a
      class="nav-link inline-block text-lg font-light tracking-[0.03em] text-vmv-sand-1/90 transition-colors duration-450 hover:text-vmv-sand-1"
      href="/#nosotros">Nosotros</a
    >
    <a
      class="nav-link inline-block text-lg font-light tracking-[0.03em] text-vmv-sand-1/90 transition-colors duration-450 hover:text-vmv-sand-1"
      href="/#servicios">Servicios</a
    >
    <a
      class="nav-link inline-block text-lg font-light tracking-[0.03em] text-vmv-sand-1/90 transition-colors duration-450 hover:text-vmv-sand-1"
      href="/projects">Proyectos</a
    >
  </nav>

  <div
    class="top-right fixed top-4 right-4 z-60 flex h-12 items-stretch sm:h-16 md:top-6 md:right-8"
  >
    <Button href="/#contacto" variant="header" class="header-cta h-full px-10" size="xxl"
      >Contacto</Button
    >

    <button
      id="menu-toggle"
      type="button"
      class="menu-toggle relative inline-flex h-12 w-12 items-center justify-center border border-vmv-sand-1/30 bg-vmv-gray-12/80 text-vmv-sand-1 transition-[color,border-color,background-color,transform] duration-550 ease-[cubic-bezier(0.22,1,0.36,1)] hover:scale-[1.02] sm:h-16 sm:w-16 md:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="menu-toggle-icon relative inline-block h-6 w-6" aria-hidden="true">
        <span
          class="line absolute block h-[0.09rem] w-full origin-center bg-current transition-[transform,opacity] duration-450 ease-[cubic-bezier(0.22,1,0.36,1)]"
        ></span>
        <span
          class="line absolute block h-[0.09rem] w-full origin-center bg-current transition-[transform,opacity] duration-450 ease-[cubic-bezier(0.22,1,0.36,1)]"
        ></span>
        <span
          class="line absolute block h-[0.09rem] w-full origin-center bg-current transition-[transform,opacity] duration-450 ease-[cubic-bezier(0.22,1,0.36,1)]"
        ></span>
      </span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="mobile-menu pointer-events-none fixed inset-0 z-40 opacity-0 transition-opacity duration-450 md:hidden"
    aria-hidden="true"
  >
    <div
      class="mobile-panel absolute inset-0 flex min-h-screen w-full flex-col bg-vmv-gray-12 px-4 py-6 text-vmv-sand-1 transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] md:px-8 md:py-8"
    >
      <div class="mt-24 mb-6 flex items-center justify-center gap-4">
        <a href="/" class="logo-link shrink-0" aria-label="Inicio VMV Arquitectos">
          <img
            src={logoVmv.src}
            alt="VMV Arquitectos"
            class="h-16 w-auto md:h-26"
            loading="eager"
          />
        </a>
      </div>

      <ul
        class="menu-links mx-auto flex h-full max-w-160 flex-col items-center justify-center gap-5 text-center"
      >
        <li>
          <a
            class="mobile-link inline-block text-[clamp(1.85rem,4.5vw,3.7rem)] leading-[1.08] font-light tracking-[0.03em] text-vmv-sand-1/94 transition-[transform,color,opacity] duration-450 hover:text-vmv-sand-1"
            href="/#nosotros">Nosotros</a
          >
        </li>
        <!-- <li>
          <a
            class="mobile-link inline-block text-[clamp(1.85rem,4.5vw,3.7rem)] leading-[1.08] font-light tracking-[0.03em] text-vmv-sand-1/94 transition-[transform,color,opacity] duration-450 hover:text-vmv-sand-1"
            href="/#galeria">Galeria</a
          >
        </li> -->
        <li>
          <a
            class="mobile-link inline-block text-[clamp(1.85rem,4.5vw,3.7rem)] leading-[1.08] font-light tracking-[0.03em] text-vmv-sand-1/94 transition-[transform,color,opacity] duration-450 hover:text-vmv-sand-1"
            href="/#servicios">Servicios</a
          >
        </li>
        <li>
          <a
            class="mobile-link inline-block text-[clamp(1.85rem,4.5vw,3.7rem)] leading-[1.08] font-light tracking-[0.03em] text-vmv-sand-1/94 transition-[transform,color,opacity] duration-450 hover:text-vmv-sand-1"
            href="/projects">Proyectos</a
          >
        </li>
        <li>
          <a
            class="mobile-link inline-block text-[clamp(1.85rem,4.5vw,3.7rem)] leading-[1.08] font-light tracking-[0.03em] text-vmv-sand-1/94 transition-[transform,color,opacity] duration-450 hover:text-vmv-sand-1"
            href="/#contacto">Contacto</a
          >
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  import { $, $$ } from '@/lib/dom-selector'

  const setupHeader = () => {
    const header = $('#site-header')
    const menuToggle = $('#menu-toggle')
    const menuClose = $('#menu-close')
    const mobileMenu = $('#mobile-menu')

    if (!header) {
      return
    }

    // Prevent duplicate handlers after Astro client-side navigation.
    ;(header as HTMLElement & { __abortController?: AbortController }).__abortController?.abort()

    const controller = new AbortController()
    ;(header as HTMLElement & { __abortController?: AbortController }).__abortController =
      controller
    const { signal } = controller

    let ticking = false
    let previousBodyPaddingRight = ''
    let closeAnimationTimer: number | undefined

    const lockBodyScroll = () => {
      const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth
      previousBodyPaddingRight = document.body.style.paddingRight
      document.body.style.overflow = 'hidden'

      if (scrollbarWidth > 0) {
        document.body.style.paddingRight = `${scrollbarWidth}px`
      }
    }

    const unlockBodyScroll = () => {
      document.body.style.overflow = ''
      document.body.style.paddingRight = previousBodyPaddingRight
    }

    const closeMenu = () => {
      if (!mobileMenu) {
        return
      }

      window.clearTimeout(closeAnimationTimer)
      unlockBodyScroll()
      menuToggle?.setAttribute('aria-expanded', 'false')
      mobileMenu.setAttribute('aria-hidden', 'true')
      mobileMenu.classList.remove('is-open')
      mobileMenu.classList.add('is-closing')
      header.classList.remove('is-menu-open')

      closeAnimationTimer = window.setTimeout(() => {
        mobileMenu.classList.remove('is-closing')
      }, 430)
    }

    const openMenu = () => {
      if (!menuToggle || !mobileMenu) {
        return
      }

      window.clearTimeout(closeAnimationTimer)
      mobileMenu.classList.remove('is-closing')
      lockBodyScroll()
      menuToggle.setAttribute('aria-expanded', 'true')
      mobileMenu.setAttribute('aria-hidden', 'false')
      mobileMenu.classList.add('is-open')
      header.classList.add('is-menu-open')
      header.classList.remove('is-hidden')
    }

    const syncScrollState = () => {
      const currentScrollY = window.scrollY
      const isScrolled = currentScrollY > 34

      header.classList.toggle('is-scrolled', isScrolled)
      header.classList.toggle('is-top', currentScrollY <= 20)
      ticking = false
    }

    const onScroll = () => {
      if (ticking) {
        return
      }
      ticking = true
      window.requestAnimationFrame(syncScrollState)
    }

    syncScrollState()
    window.addEventListener('scroll', onScroll, { passive: true, signal })

    if (menuToggle && mobileMenu) {
      const links = $$('a', mobileMenu)

      menuToggle.addEventListener(
        'click',
        () => {
          const expanded = menuToggle.getAttribute('aria-expanded') === 'true'
          if (expanded) {
            closeMenu()
            return
          }
          openMenu()
        },
        { signal },
      )

      links.forEach((link) => {
        link.addEventListener('click', closeMenu, { signal })
      })

      menuClose?.addEventListener('click', closeMenu, { signal })

      mobileMenu.addEventListener(
        'click',
        (event) => {
          if (event.target === mobileMenu) {
            closeMenu()
          }
        },
        { signal },
      )

      window.addEventListener(
        'keydown',
        (event) => {
          if (event.key === 'Escape') {
            closeMenu()
          }
        },
        { signal },
      )
    }

    signal.addEventListener('abort', closeMenu, { once: true })
  }

  document.addEventListener('astro:page-load', setupHeader)
  setupHeader()
</script>

<style>
  .group.is-hidden {
    transform: translateY(-125%);
  }

  .group .header-cta {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background-color: transparent;
  }

  .group .header-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background-color: var(--vmv-sand-9);
    clip-path: inset(0 0 0 100%);
    transition: clip-path 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: clip-path;
  }

  .group.is-scrolled .header-shell,
  .group.is-menu-open .header-shell {
  }

  .menu-toggle .line:first-of-type {
    top: 0;
  }

  .menu-toggle .line:nth-of-type(2) {
    top: 50%;
    transform: translateY(-50%);
  }

  .menu-toggle .line:last-of-type {
    bottom: 0;
  }

  .menu-toggle[aria-expanded='true'] .line:first-of-type {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }

  .menu-toggle[aria-expanded='true'] .line:nth-of-type(2) {
    opacity: 0;
  }

  .menu-toggle[aria-expanded='true'] .line:last-of-type {
    bottom: auto;
    top: 50%;
    transform: translateY(-50%) rotate(-45deg);
  }

  .logo-link img {
    filter: brightness(0) invert(1);
    transition: filter 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-panel {
    transform-origin: top;
    transform: scaleY(0);
  }

  .mobile-link {
    opacity: 0;
  }

  .mobile-menu.is-open {
    pointer-events: auto;
    opacity: 1;
  }

  .mobile-menu.is-open .mobile-panel {
    transform: scaleY(1);
  }

  .mobile-menu.is-open .mobile-link {
    animation: menuLinkFadeIn 0.45s ease forwards;
  }

  .mobile-menu.is-open li:nth-child(1) .mobile-link {
    animation-delay: 0.08s;
  }

  .mobile-menu.is-open li:nth-child(2) .mobile-link {
    animation-delay: 0.14s;
  }

  .mobile-menu.is-open li:nth-child(3) .mobile-link {
    animation-delay: 0.2s;
  }

  .mobile-menu.is-open li:nth-child(4) .mobile-link {
    animation-delay: 0.26s;
  }

  .mobile-menu.is-open li:nth-child(5) .mobile-link {
    animation-delay: 0.32s;
  }

  .mobile-menu.is-closing {
    pointer-events: none;
    opacity: 1;
  }

  .mobile-menu.is-closing .mobile-panel {
    transform: scaleY(0);
  }

  .mobile-menu.is-closing .mobile-link {
    opacity: 0;
  }

  /* .group.is-scrolled .menu-toggle, */
  .group .menu-toggle,
  .group.is-menu-open .menu-toggle {
    color: color-mix(in srgb, var(--vmv-sand-1) 95%, transparent);
    border-color: color-mix(in srgb, var(--vmv-sand-1) 30%, transparent);
    background: color-mix(in srgb, var(--vmv-gray-12) 80%, transparent);
  }

  .group.is-scrolled .logo-link img,
  .group.is-menu-open .logo-link img {
    /* filter: none; */
    /* background-color: var(--vmv-sand-9); */
  }

  .group.is-scrolled .header-cta,
  .group.is-menu-open .header-cta {
  }

  .group.is-scrolled .header-cta::before,
  .group.is-menu-open .header-cta::before {
    clip-path: inset(0 0 0 0);
  }

  .group .header-cta,
  .group.is-menu-open .header-cta,
  .group .menu-contact-cta {
    color: white;
  }

  .group.is-scrolled .header-cta,
  .group.is-menu-open .header-cta {
    /* color: color-mix(in srgb, var(--vmv-gray-12) 90%, transparent); */
  }

  @keyframes headerReveal {
    from {
      opacity: 0;
      transform: translateY(-18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes menuLinkFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .header-shell,
    .mobile-panel,
    .mobile-link,
    .header-cta,
    .header-cta::before,
    .menu-toggle .line {
      animation: none;
      transition: none;
    }
  }
</style>
