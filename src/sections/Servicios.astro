---
import Button from '@/components/ui/Button.astro'
import { servicios } from '@/data/servicios'

const totalLabel = String(servicios.length).padStart(2, '0')
---

<section
  id="servicios"
  class="relative bg-vmv-background"
  data-servicios
  aria-label="Servicios de la constructora"
>
  <div
    class="relative min-[900px]:motion-safe:h-screen min-[900px]:motion-safe:overflow-hidden"
    data-servicios-stage
  >
    <div
      class="pointer-events-none absolute inset-x-[clamp(2rem,6vw,6rem)] top-[6%] hidden select-none min-[900px]:motion-safe:block"
      aria-hidden="true"
      data-servicios-words
    >
      <!-- {
        servicios.map((servicio) => (
          <span
            class="vmv-display-1 invisible absolute top-0 left-0 whitespace-nowrap text-vmv-foreground/12 uppercase"
            data-servicios-word
          >
            {servicio.footer}
          </span>
        ))
      } -->
    </div>
    <div
      class="flex flex-col gap-10 py-[clamp(3.5rem,8vw,6rem)] min-[900px]:motion-safe:h-full min-[900px]:motion-safe:w-max min-[900px]:motion-safe:flex-row min-[900px]:motion-safe:items-center min-[900px]:motion-safe:gap-[clamp(2rem,4vw,4.5rem)] min-[900px]:motion-safe:py-0 min-[900px]:motion-safe:pr-[clamp(2rem,6vw,6rem)] min-[900px]:motion-safe:pl-[clamp(2rem,6vw,6rem)] min-[900px]:motion-safe:will-change-transform"
      data-servicios-track
    >
      <header
        class="flex flex-col items-center gap-6 px-[clamp(1.25rem,5vw,3rem)] text-left min-[900px]:motion-safe:w-[clamp(24rem,36vw,32rem)] min-[900px]:motion-safe:shrink-0 min-[900px]:motion-safe:px-0 min-[900px]:motion-safe:pr-[clamp(2rem,5vw,5rem)]"
        data-servicios-intro
      >
        <p class="vmv-overline-1 flex items-center gap-3 text-vmv-sand-9">
          <span class="h-px w-9 bg-vmv-sand-9/60" aria-hidden="true"></span>
          Nuestros servicios
        </p>
        <h2 class="vmv-title-1 max-w-[12ch] text-center text-vmv-foreground">
          Construimos cada etapa
        </h2>
        <p class="vmv-body-2 max-w-[42ch] text-vmv-muted-foreground text-center">
          Acompañamos tu proyecto del concepto a la obra terminada, con un equipo que cuida el
          diseño, los tiempos y cada acabado.
        </p>
        <Button href="#contacto" variant="outline" size="xl" class="mt-2">
          Conversemos tu proyecto
        </Button>
      </header>

      <div
        class="flex snap-x snap-mandatory scroll-px-[clamp(1.25rem,5vw,3rem)] scrollbar-none gap-4 overflow-x-auto overscroll-x-contain px-[clamp(1.25rem,5vw,3rem)] pb-4 min-[900px]:motion-safe:contents sm:gap-6 [&::-webkit-scrollbar]:hidden"
      >
        {
          servicios.map((servicio, index) => (
            <article
              class="group relative w-[min(82vw,21rem)] shrink-0 snap-start min-[900px]:motion-safe:w-auto min-[900px]:motion-safe:even:top-[clamp(0.5rem,2dvh,1.5rem)] sm:w-[clamp(18rem,46vw,22rem)] hover:cursor-pointer"
              data-servicios-card
            >
              <figure class="relative aspect-[3.6/5.3] w-full rounded-sm overflow-hidden min-[900px]:motion-safe:h-[clamp(18rem,52dvh,29rem)] min-[900px]:motion-safe:w-auto">
                <div class="absolute inset-0 transition-transform duration-900 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.05] group-data-[active=true]:scale-[1.05]">
                  <img
                    src={servicio.image}
                    alt={servicio.imageAlt}
                    class="absolute top-0 h-full w-[110%] object-cover translate-x-1 grayscale transition-[filter] duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:grayscale-0 group-data-[active=true]:grayscale-0"
                    data-servicios-image
                    loading="lazy"
                    decoding="async"
                  />
                  <div
                    class="absolute inset-0 bg-[#5c4938]/35 mix-blend-multiply transition-opacity duration-700 group-hover:opacity-0 group-data-[active=true]:opacity-0"
                    aria-hidden="true"
                  />
                </div>
                <div
                  class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,9,8,0.12)_0%,transparent_38%,rgba(10,9,8,0.82)_100%)]"
                  aria-hidden="true"
                />
                <div
                  class="pointer-events-none absolute inset-0 rounded-sm ring-1 ring-white/12 ring-inset"
                  aria-hidden="true"
                />
                <figcaption class="absolute inset-x-0 bottom-0 flex flex-col gap-2.5 p-[clamp(1.25rem,2vw,1.75rem)]">
                  <span
                    class="h-px w-9 bg-white/40 transition-[width,background-color] duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:w-14 group-hover:bg-white/75 group-data-[active=true]:w-14 group-data-[active=true]:bg-white/75"
                    aria-hidden="true"
                  />
                  <h3 class="vmv-title-3 tracking-[0.08em] text-balance text-white uppercase">
                    {servicio.title}
                  </h3>
                  <div class="grid max-w-[32ch]">
                    {/* <p class="vmv-body-3 col-start-1 row-start-1 text-white/72 transition-[opacity,transform] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:-translate-y-1 group-hover:opacity-0 group-data-[active=true]:-translate-y-1 group-data-[active=true]:opacity-0">
                      {servicio.description}
                    </p> */}
                    {/* <p class="vmv-body-3 pointer-events-none col-start-1 row-start-1 translate-y-2 self-start text-white/72 opacity-0 transition-[opacity,transform] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] delay-100 group-hover:translate-y-0 group-hover:opacity-100 group-data-[active=true]:translate-y-0 group-data-[active=true]:opacity-100">
                      {servicio.details}
                    </p> */}
                  </div>
                </figcaption>
              </figure>
              {/* <div class="mt-4 h-px w-full bg-vmv-border">
                <div
                  class="h-full origin-left scale-x-0 bg-vmv-foreground transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-x-100 group-data-[active=true]:scale-x-100"
                  aria-hidden="true"
                />
              </div>
              <div class="mt-3 flex items-baseline justify-between">
                <span
                  class="vmv-subtitle-1 text-vmv-sand-9/55 tabular-nums"
                  aria-hidden="true"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="vmv-caption-1 tracking-[0.22em] text-vmv-muted-foreground uppercase">
                  {servicio.footer}
                </span>
              </div> */}
            </article>
          ))
        }
      </div>
    </div>

    <footer
      class="pointer-events-none absolute inset-x-[clamp(2rem,6vw,6rem)] bottom-[clamp(1.25rem,3vw,2rem)] z-2 hidden flex-col gap-3 min-[900px]:motion-safe:flex"
    >
      <div class="flex items-center justify-between">
        <span
          class="vmv-caption-1 tracking-[0.22em] text-vmv-muted-foreground uppercase"
          aria-hidden="true"
        >
          VMV — Servicios
        </span>
        <div class="flex items-center gap-4">
          <span
            class="vmv-caption-1 tracking-[0.22em] text-vmv-muted-foreground tabular-nums"
            aria-hidden="true"
          >
            <span data-servicios-counter>01</span> / {totalLabel}
          </span>
          <div class="pointer-events-auto flex items-center gap-2">
            <button
              type="button"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-vmv-border text-vmv-foreground transition-colors duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] hover:border-vmv-gray-6 hover:bg-vmv-muted disabled:pointer-events-none disabled:opacity-30"
              data-servicios-prev
              aria-label="Servicio anterior"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M10 3.5L5 8l5 4.5"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </button>
            <button
              type="button"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-vmv-border text-vmv-foreground transition-colors duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] hover:border-vmv-gray-6 hover:bg-vmv-muted disabled:pointer-events-none disabled:opacity-30"
              data-servicios-next
              aria-label="Siguiente servicio"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M6 3.5l5 4.5-5 4.5"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
      <div class="h-px w-full bg-vmv-foreground/12">
        <div
          class="h-full origin-left transform-[scaleX(0)] bg-vmv-foreground"
          data-servicios-progress
        >
        </div>
      </div>
    </footer>
  </div>
</section>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { SplitText } from 'gsap/SplitText'
  import { $, $$ } from '@/lib/dom-selector'

  gsap.registerPlugin(ScrollTrigger, SplitText)

  let cleanupServicios: (() => void) | null = null

  const setupServicios = () => {
    if (cleanupServicios) {
      cleanupServicios()
      cleanupServicios = null
    }

    const section = $<HTMLElement>('[data-servicios]')
    if (!section) {
      return
    }

    const stage = $<HTMLElement>('[data-servicios-stage]', section)
    const track = $<HTMLElement>('[data-servicios-track]', section)
    const intro = $<HTMLElement>('[data-servicios-intro]', section)
    const cards = $$<HTMLElement>('[data-servicios-card]', section)
    const images = $$<HTMLImageElement>('[data-servicios-image]', section)
    const progressBar = $<HTMLElement>('[data-servicios-progress]', section)
    const counter = $<HTMLElement>('[data-servicios-counter]', section)
    const wordsLayer = $<HTMLElement>('[data-servicios-words]', section)
    const words = $$<HTMLElement>('[data-servicios-word]', section)
    const prevButton = $<HTMLButtonElement>('[data-servicios-prev]', section)
    const nextButton = $<HTMLButtonElement>('[data-servicios-next]', section)

    if (!stage || !track || cards.length === 0) {
      return
    }

    // Tap para fijar el efecto "hover" en pantallas táctiles: alterna
    // data-active en la tarjeta y se mantiene hasta el próximo toque.
    const tapController = new AbortController()
    cards.forEach((card) => {
      card.addEventListener(
        'click',
        () => {
          const isActive = card.dataset.active === 'true'
          cards.forEach((c) => delete c.dataset.active)
          if (!isActive) {
            card.dataset.active = 'true'
          }
        },
        { signal: tapController.signal },
      )
    })

    const mm = gsap.matchMedia()

    // Debe coincidir con las variantes `min-[900px]:motion-safe:` del markup.
    mm.add('(min-width: 900px) and (prefers-reduced-motion: no-preference)', () => {
      const getDistance = () => track.scrollWidth - stage.clientWidth

      const scrollFactor = 2.6

      const splits = words.map((word) => new SplitText(word, { type: 'chars', aria: 'none' }))

      let activeWordIndex = -1
      const setActiveWord = (index: number) => {
        const nextWord = words[index]
        const nextSplit = splits[index]
        if (index === activeWordIndex || !nextWord || !nextSplit) {
          return
        }
        const currentSplit = splits[activeWordIndex]
        activeWordIndex = index
        if (currentSplit) {
          gsap.to(currentSplit.chars, {
            yPercent: -40,
            autoAlpha: 0,
            duration: 0.6,
            ease: 'sine.in',
            stagger: 0.025,
            overwrite: 'auto',
          })
        }
        gsap.set(nextWord, { autoAlpha: 1 })
        gsap.fromTo(
          nextSplit.chars,
          { yPercent: 60, autoAlpha: 0 },
          {
            yPercent: 0,
            autoAlpha: 1,
            duration: 1.2,
            ease: 'expo.out',
            stagger: 0.04,
            overwrite: 'auto',
          },
        )
      }

      let currentIndex = 0

      const updateNavButtons = () => {
        if (prevButton) {
          prevButton.disabled = currentIndex <= 0
        }
        if (nextButton) {
          nextButton.disabled = currentIndex >= cards.length - 1
        }
      }

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: () => `+=${getDistance() * scrollFactor}`,
          scrub: 2.5,
          pin: stage,
          pinSpacing: true,
          anticipatePin: 1,
          invalidateOnRefresh: true,
          onUpdate: (self) => {
            currentIndex = Math.round(self.progress * (cards.length - 1))
            if (counter) {
              counter.textContent = String(currentIndex + 1).padStart(2, '0')
            }
            setActiveWord(currentIndex)
            updateNavButtons()
          },
        },
      })

      const goToIndex = (index: number) => {
        const scrollTrigger = tl.scrollTrigger
        if (!scrollTrigger) {
          return
        }
        const clampedIndex = Math.max(0, Math.min(cards.length - 1, index))
        const progress = cards.length > 1 ? clampedIndex / (cards.length - 1) : 0
        const target = scrollTrigger.start + progress * (scrollTrigger.end - scrollTrigger.start)
        const lenis = window.lenis
        if (lenis) {
          lenis.scrollTo(target, { duration: 1.2 })
        } else {
          window.scrollTo({ top: target, behavior: 'smooth' })
        }
      }

      const navController = new AbortController()
      prevButton?.addEventListener('click', () => goToIndex(currentIndex - 1), {
        signal: navController.signal,
      })
      nextButton?.addEventListener('click', () => goToIndex(currentIndex + 1), {
        signal: navController.signal,
      })
      updateNavButtons()

      tl.to(track, {
        x: () => -getDistance(),
        ease: 'none',
      })

      if (progressBar) {
        tl.fromTo(progressBar, { scaleX: 0 }, { scaleX: 1, ease: 'none' }, 0)
      }

      if (wordsLayer) {
        tl.to(wordsLayer, { xPercent: -5, ease: 'none', duration: 1 }, 0)
      }
      setActiveWord(0)

      // cards.forEach((card, index) => {
      //   const image = images[index]
      //   if (!image) {
      //     return
      //   }
      //   gsap.fromTo(
      //     image,
      //     { xPercent: -4 },
      //     {
      //       xPercent: 4,
      //       ease: 'none',
      //       scrollTrigger: {
      //         trigger: card,
      //         containerAnimation: tl,
      //         start: 'left right',
      //         end: 'right left',
      //         scrub: true,
      //       },
      //     },
      //   )
      // })

      const entrance = [intro, ...cards].filter(Boolean)
      gsap.from(entrance, {
        autoAlpha: 0,
        y: 44,
        duration: 1,
        ease: 'power3.out',
        stagger: 0.12,
        scrollTrigger: {
          trigger: section,
          start: 'top 70%',
        },
      })

      // SplitText altera el DOM: restaurar el markup original al revertir.
      return () => {
        navController.abort()
        splits.forEach((split) => split.revert())
      }
    })

    cleanupServicios = () => {
      tapController.abort()
      mm.revert()
    }
  }

  document.addEventListener('astro:before-swap', () => {
    if (cleanupServicios) {
      cleanupServicios()
      cleanupServicios = null
    }
  })

  document.addEventListener('astro:page-load', setupServicios)
  setupServicios()
</script>
