---
import Button from '@/components/ui/Button.astro'
import { servicios } from '@/data/servicios'

const totalLabel = String(servicios.length).padStart(2, '0')
---

<section
  id="servicios"
  class="relative bg-vmv-background"
  data-servicios
  aria-label="Servicios de la constructora"
>
  <div
    class="relative min-[900px]:motion-safe:h-screen min-[900px]:motion-safe:overflow-hidden"
    data-servicios-stage
  >
    <div
      class="pointer-events-none absolute inset-x-[clamp(2rem,6vw,6rem)] top-[6%] hidden select-none min-[900px]:motion-safe:block"
      aria-hidden="true"
      data-servicios-words
    >
      {
        servicios.map((servicio) => (
          <span
            class="invisible absolute top-0 left-0 text-[clamp(4rem,8.5vw,8rem)] leading-none font-thin tracking-[0.02em] whitespace-nowrap text-vmv-foreground/12 uppercase"
            data-servicios-word
          >
            {servicio.footer}
          </span>
        ))
      }
    </div>
    <div
      class="flex flex-col gap-10 py-[clamp(3.5rem,8vw,6rem)] min-[900px]:motion-safe:h-full min-[900px]:motion-safe:w-max min-[900px]:motion-safe:flex-row min-[900px]:motion-safe:items-center min-[900px]:motion-safe:gap-[clamp(2rem,4vw,4.5rem)] min-[900px]:motion-safe:py-0 min-[900px]:motion-safe:pr-[clamp(2rem,6vw,6rem)] min-[900px]:motion-safe:pl-[clamp(2rem,6vw,6rem)] min-[900px]:motion-safe:will-change-transform"
      data-servicios-track
    >
      <header
        class="flex flex-col items-center gap-6 px-[clamp(1.25rem,5vw,3rem)] text-left min-[900px]:motion-safe:w-[clamp(24rem,36vw,32rem)] min-[900px]:motion-safe:shrink-0 min-[900px]:motion-safe:px-0 min-[900px]:motion-safe:pr-[clamp(2rem,5vw,5rem)]"
        data-servicios-intro
      >
        <p class="vmv-overline-1 flex items-center gap-3 text-vmv-sand-9">
          <span class="h-px w-9 bg-vmv-sand-9/60" aria-hidden="true"></span>
          Nuestros servicios
        </p>
        <h2 class="vmv-title-1 max-w-[12ch] text-center text-vmv-foreground">
          Construimos cada etapa
        </h2>
        <p class="vmv-body-2 max-w-[42ch] text-vmv-muted-foreground text-center">
          Acompañamos tu proyecto del concepto a la obra terminada, con un equipo que cuida el
          diseño, los tiempos y cada acabado.
        </p>
        <Button href="#contacto" variant="outline" size="xl" class="mt-2">
          Conversemos tu proyecto
        </Button>
      </header>

      <div
        class="flex snap-x snap-mandatory scroll-px-[clamp(1.25rem,5vw,3rem)] scrollbar-none gap-4 overflow-x-auto overscroll-x-contain px-[clamp(1.25rem,5vw,3rem)] pb-4 min-[900px]:motion-safe:contents sm:gap-6 [&::-webkit-scrollbar]:hidden"
      >
        {
          servicios.map((servicio, index) => (
            <article
              class="group relative w-[min(82vw,21rem)] shrink-0 snap-start min-[900px]:motion-safe:w-[clamp(17rem,min(29vw,46vh),26rem)] min-[900px]:motion-safe:even:top-[clamp(1.5rem,4vh,3rem)] sm:w-[clamp(18rem,46vw,22rem)]"
              data-servicios-card
            >
              <figure class="relative aspect-[3.6/5.3] rounded-sm overflow-hidden">
                <div class="absolute inset-0 transition-transform duration-900 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.05]">
                  <img
                    src={servicio.image}
                    alt={servicio.imageAlt}
                    class="absolute top-0 h-full w-[110%] object-cover"
                    data-servicios-image
                    loading="lazy"
                    decoding="async"
                  />
                  <div
                    class="absolute inset-0 bg-[#5c4938]/35 mix-blend-multiply transition-opacity duration-700 group-hover:opacity-0"
                    aria-hidden="true"
                  />
                </div>
                <div
                  class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,9,8,0.12)_0%,transparent_38%,rgba(10,9,8,0.82)_100%)]"
                  aria-hidden="true"
                />
                <div
                  class="pointer-events-none absolute inset-0 rounded-sm ring-1 ring-white/12 ring-inset"
                  aria-hidden="true"
                />
                <figcaption class="absolute inset-x-0 bottom-0 flex flex-col gap-2.5 p-[clamp(1.25rem,2vw,1.75rem)]">
                  <span
                    class="h-px w-9 bg-white/40 transition-[width,background-color] duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:w-14 group-hover:bg-white/75"
                    aria-hidden="true"
                  />
                  <h3 class="vmv-title-3 tracking-[0.08em] text-balance text-white uppercase">
                    {servicio.title}
                  </h3>
                  <p class="vmv-body-3 max-w-[32ch] text-white/72">{servicio.description}</p>
                </figcaption>
              </figure>
              <div class="mt-4 h-px w-full bg-vmv-border">
                <div
                  class="h-full origin-left scale-x-0 bg-vmv-foreground transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-x-100"
                  aria-hidden="true"
                />
              </div>
              <div class="mt-3 flex items-baseline justify-between">
                <span
                  class="text-[clamp(1.35rem,1.8vw,1.6rem)] font-thin leading-none tracking-[-0.01em] text-vmv-sand-9/55 tabular-nums"
                  aria-hidden="true"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class="vmv-caption-1 tracking-[0.22em] text-vmv-muted-foreground uppercase">
                  {servicio.footer}
                </span>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <footer
      class="pointer-events-none absolute inset-x-[clamp(2rem,6vw,6rem)] bottom-[clamp(1.25rem,3vw,2rem)] z-2 hidden flex-col gap-3 min-[900px]:motion-safe:flex"
      aria-hidden="true"
    >
      <div class="flex items-baseline justify-between">
        <span class="vmv-caption-1 tracking-[0.22em] text-vmv-muted-foreground uppercase">
          VMV — Servicios
        </span>
        <span class="vmv-caption-1 tracking-[0.22em] text-vmv-muted-foreground tabular-nums">
          <span data-servicios-counter>01</span> / {totalLabel}
        </span>
      </div>
      <div class="h-px w-full bg-vmv-foreground/12">
        <div
          class="h-full origin-left transform-[scaleX(0)] bg-vmv-foreground"
          data-servicios-progress
        >
        </div>
      </div>
    </footer>
  </div>
</section>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { SplitText } from 'gsap/SplitText'
  import { $, $$ } from '@/lib/dom-selector'

  gsap.registerPlugin(ScrollTrigger, SplitText)

  let cleanupServicios: (() => void) | null = null

  const setupServicios = () => {
    if (cleanupServicios) {
      cleanupServicios()
      cleanupServicios = null
    }

    const section = $<HTMLElement>('[data-servicios]')
    if (!section) {
      return
    }

    const stage = $<HTMLElement>('[data-servicios-stage]', section)
    const track = $<HTMLElement>('[data-servicios-track]', section)
    const intro = $<HTMLElement>('[data-servicios-intro]', section)
    const cards = $$<HTMLElement>('[data-servicios-card]', section)
    const images = $$<HTMLImageElement>('[data-servicios-image]', section)
    const progressBar = $<HTMLElement>('[data-servicios-progress]', section)
    const counter = $<HTMLElement>('[data-servicios-counter]', section)
    const wordsLayer = $<HTMLElement>('[data-servicios-words]', section)
    const words = $$<HTMLElement>('[data-servicios-word]', section)

    if (!stage || !track || cards.length === 0) {
      return
    }

    const mm = gsap.matchMedia()

    // Debe coincidir con las variantes `min-[900px]:motion-safe:` del markup.
    mm.add('(min-width: 900px) and (prefers-reduced-motion: no-preference)', () => {
      const getDistance = () => track.scrollWidth - stage.clientWidth

      const scrollFactor = 2.6

      const splits = words.map((word) => new SplitText(word, { type: 'chars', aria: 'none' }))

      let activeWordIndex = -1
      const setActiveWord = (index: number) => {
        const nextWord = words[index]
        const nextSplit = splits[index]
        if (index === activeWordIndex || !nextWord || !nextSplit) {
          return
        }
        const currentSplit = splits[activeWordIndex]
        activeWordIndex = index
        if (currentSplit) {
          gsap.to(currentSplit.chars, {
            yPercent: -40,
            autoAlpha: 0,
            duration: 0.6,
            ease: 'sine.in',
            stagger: 0.025,
            overwrite: 'auto',
          })
        }
        gsap.set(nextWord, { autoAlpha: 1 })
        gsap.fromTo(
          nextSplit.chars,
          { yPercent: 60, autoAlpha: 0 },
          {
            yPercent: 0,
            autoAlpha: 1,
            duration: 1.2,
            ease: 'expo.out',
            stagger: 0.04,
            overwrite: 'auto',
          },
        )
      }

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: () => `+=${getDistance() * scrollFactor}`,
          scrub: 2.5,
          pin: stage,
          pinSpacing: true,
          anticipatePin: 1,
          invalidateOnRefresh: true,
          onUpdate: (self) => {
            const index = Math.round(self.progress * (cards.length - 1))
            if (counter) {
              counter.textContent = String(index + 1).padStart(2, '0')
            }
            setActiveWord(index)
          },
        },
      })

      tl.to(track, {
        x: () => -getDistance(),
        ease: 'none',
      })

      if (progressBar) {
        tl.fromTo(progressBar, { scaleX: 0 }, { scaleX: 1, ease: 'none' }, 0)
      }

      if (wordsLayer) {
        tl.to(wordsLayer, { xPercent: -5, ease: 'none', duration: 1 }, 0)
      }
      setActiveWord(0)

      cards.forEach((card, index) => {
        const image = images[index]
        if (!image) {
          return
        }
        gsap.fromTo(
          image,
          { xPercent: -4 },
          {
            xPercent: 4,
            ease: 'none',
            scrollTrigger: {
              trigger: card,
              containerAnimation: tl,
              start: 'left right',
              end: 'right left',
              scrub: true,
            },
          },
        )
      })

      const entrance = [intro, ...cards].filter(Boolean)
      gsap.from(entrance, {
        autoAlpha: 0,
        y: 44,
        duration: 1,
        ease: 'power3.out',
        stagger: 0.12,
        scrollTrigger: {
          trigger: section,
          start: 'top 70%',
        },
      })

      // SplitText altera el DOM: restaurar el markup original al revertir.
      return () => {
        splits.forEach((split) => split.revert())
      }
    })

    cleanupServicios = () => {
      mm.revert()
    }
  }

  document.addEventListener('astro:before-swap', () => {
    if (cleanupServicios) {
      cleanupServicios()
      cleanupServicios = null
    }
  })

  document.addEventListener('astro:page-load', setupServicios)
  setupServicios()
</script>
