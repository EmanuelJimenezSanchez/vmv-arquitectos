---
import Layout from '@/layouts/Layout.astro'
import { getProjectById } from '@/data/projects'

const id = Astro.params.id ?? ''
const project = getProjectById(id)

if (!project) {
  Astro.response.status = 404
}

const canonical = project
  ? `https://www.vmv-arquitectos.com/projects/${project.id}`
  : 'https://www.vmv-arquitectos.com/projects'
const title = project ? `${project.title} | Proyecto | VMV Arquitectos` : 'Proyecto no encontrado | VMV Arquitectos'
---

<Layout title={title} description={project?.summary ?? 'Proyecto no encontrado.'} canonical={canonical}>
  {project ? (
  <section class="mx-auto w-full max-w-5xl px-6 py-24 md:px-10">
    <a href="/projects" class="vmv-caption-1 inline-flex items-center text-vmv-muted-foreground underline underline-offset-4">
      Ver todos los proyectos
    </a>

    <header class="mt-8 grid gap-6 md:grid-cols-[1.1fr_1fr] md:items-end">
      <div>
        <p class="vmv-overline-1 text-vmv-sand-9">Proyecto</p>
        <h1 class="vmv-title-1 mt-2 text-vmv-foreground">{project.title}</h1>
        <p class="vmv-body-1 mt-5 text-vmv-muted-foreground">{project.summary}</p>
      </div>

      <dl class="vmv-body-3 grid grid-cols-2 gap-4 rounded-2xl border border-vmv-border bg-vmv-muted p-5">
        <div>
          <dt class="text-vmv-muted-foreground">Ubicacion</dt>
          <dd class="mt-1 font-medium text-vmv-foreground">{project.location}</dd>
        </div>
        <div>
          <dt class="text-vmv-muted-foreground">Ano</dt>
          <dd class="mt-1 font-medium text-vmv-foreground">{project.year}</dd>
        </div>
      </dl>
    </header>

    <img
      src={project.coverImage}
      alt={`Imagen principal del proyecto ${project.title}`}
      class="mt-10 h-[320px] w-full rounded-3xl object-cover md:h-[460px]"
      loading="eager"
      decoding="async"
    />

    <section class="mt-10 grid gap-10 md:grid-cols-[1fr_260px]">
      <div class="vmv-body-1 space-y-5 text-vmv-foreground">
        {project.content.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>

      <aside class="rounded-2xl border border-vmv-border p-5">
        <h2 class="vmv-caption-1 text-vmv-muted-foreground">Servicios</h2>
        <ul class="vmv-body-3 mt-4 space-y-2 text-vmv-muted-foreground">
          {project.services.map((service) => (
            <li>{service}</li>
          ))}
        </ul>
      </aside>
    </section>
  </section>
  ) : (
  <section class="mx-auto w-full max-w-3xl px-6 py-24 text-center md:px-10">
    <p class="vmv-overline-1 text-vmv-sand-9">404</p>
    <h1 class="vmv-title-1 mt-3 text-vmv-foreground">Proyecto no encontrado</h1>
    <p class="vmv-body-1 mt-4 text-vmv-muted-foreground">El identificador solicitado no existe o aun no esta publicado.</p>
    <a href="/projects" class="vmv-caption-1 mt-8 inline-flex text-vmv-foreground underline underline-offset-4">
      Ir al listado de proyectos
    </a>
  </section>
  )}
</Layout>
