---
import Layout from '@/layouts/Layout.astro'
import { getProjectById } from '@/data/projects'

const id = Astro.params.id ?? ''
const project = getProjectById(id)

if (!project) {
  Astro.response.status = 404
}

const canonical = project
  ? `https://www.vmv-arquitectos.com/projects/${project.id}`
  : 'https://www.vmv-arquitectos.com/projects'
const title = project ? `${project.title} | Proyecto | VMV Arquitectos` : 'Proyecto no encontrado | VMV Arquitectos'
---

<Layout title={title} description={project?.summary ?? 'Proyecto no encontrado.'} canonical={canonical}>
  {project ? (
  <section class="mx-auto w-full max-w-5xl px-6 py-24 md:px-10">
    <a href="/projects" class="inline-flex items-center text-sm font-medium text-neutral-700 underline underline-offset-4">
      Ver todos los proyectos
    </a>

    <header class="mt-8 grid gap-6 md:grid-cols-[1.1fr_1fr] md:items-end">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-neutral-500">Proyecto</p>
        <h1 class="mt-2 text-4xl font-semibold leading-tight text-neutral-900 md:text-5xl">{project.title}</h1>
        <p class="mt-5 text-base leading-relaxed text-neutral-700">{project.summary}</p>
      </div>

      <dl class="grid grid-cols-2 gap-4 rounded-2xl border border-neutral-200 bg-neutral-50 p-5 text-sm">
        <div>
          <dt class="text-neutral-500">Ubicacion</dt>
          <dd class="mt-1 font-medium text-neutral-900">{project.location}</dd>
        </div>
        <div>
          <dt class="text-neutral-500">Ano</dt>
          <dd class="mt-1 font-medium text-neutral-900">{project.year}</dd>
        </div>
      </dl>
    </header>

    <img
      src={project.coverImage}
      alt={`Imagen principal del proyecto ${project.title}`}
      class="mt-10 h-[320px] w-full rounded-3xl object-cover md:h-[460px]"
      loading="eager"
      decoding="async"
    />

    <section class="mt-10 grid gap-10 md:grid-cols-[1fr_260px]">
      <div class="space-y-5 text-neutral-800">
        {project.content.map((paragraph) => (
          <p class="leading-relaxed">{paragraph}</p>
        ))}
      </div>

      <aside class="rounded-2xl border border-neutral-200 p-5">
        <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-neutral-700">Servicios</h2>
        <ul class="mt-4 space-y-2 text-sm text-neutral-700">
          {project.services.map((service) => (
            <li>{service}</li>
          ))}
        </ul>
      </aside>
    </section>
  </section>
  ) : (
  <section class="mx-auto w-full max-w-3xl px-6 py-24 text-center md:px-10">
    <p class="text-xs uppercase tracking-[0.18em] text-neutral-500">404</p>
    <h1 class="mt-3 text-3xl font-semibold text-neutral-900 md:text-4xl">Proyecto no encontrado</h1>
    <p class="mt-4 text-neutral-700">El identificador solicitado no existe o aun no esta publicado.</p>
    <a href="/projects" class="mt-8 inline-flex text-sm font-medium text-neutral-900 underline underline-offset-4">
      Ir al listado de proyectos
    </a>
  </section>
  )}
</Layout>
