---
import Layout from '@/layouts/Layout.astro'
import { projects } from '@/data/projects'

const title = 'Proyectos | VMV Arquitectos'
const description = 'Explora los proyectos de VMV Arquitectos.'
const canonical = 'https://www.vmv-arquitectos.com/projects'
---

<Layout title={title} description={description} canonical={canonical}>
  <section class="mx-auto w-full max-w-6xl px-6 py-24 md:px-10">
    <header class="max-w-2xl">
      <p class="vmv-overline-1 text-vmv-sand-9">Portafolio</p>
      <h1 class="vmv-title-1 mt-2 text-vmv-foreground">Proyectos</h1>
      <p class="vmv-body-1 mt-4 text-vmv-muted-foreground">
        Cada proyecto tiene su ruta dinamica por id para facilitar gestion y escalabilidad dentro del mismo repositorio.
      </p>
    </header>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <article class="overflow-hidden rounded-2xl border border-vmv-border bg-vmv-card">
          <img
            src={project.coverImage}
            alt={`Imagen del proyecto ${project.title}`}
            class="h-48 w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="space-y-3 p-5">
            <h2 class="vmv-title-3 text-vmv-foreground">{project.title}</h2>
            <p class="vmv-body-3 text-vmv-muted-foreground">{project.location} - {project.year}</p>
            <p class="vmv-body-3 text-vmv-muted-foreground">{project.summary}</p>
            <a href={`/projects/${project.id}`} class="vmv-caption-1 inline-flex text-vmv-foreground underline underline-offset-4">
              Ver detalle
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
