---
import Layout from '../layouts/Layout.astro';
import Alcance from '../sections/Alcance.astro';
import Contacto from '../sections/Contacto.astro';
import Footer from '../sections/Footer.astro';
import Galeria from '../sections/Galeria.astro';
import Hero from '../sections/Hero.astro';
import Nosotros from '../sections/Nosotros.astro';
import Proceso from '../sections/Proceso.astro';
import Servicios from '../sections/Servicios.astro';

const SITE_URL = 'https://www.vmv-arquitectos.com'
const title = 'VMV Arquitectos - Diseño y Construcción de Espacios Funcionales y Estéticos'
const description =
  'VMV Arquitectos - Diseño y Construcción de Espacios Funcionales y Estéticos'
const canonical = `${SITE_URL}/`
---

<Layout title={title} description={description} canonical={canonical}>
	<Hero />
  <Nosotros />
  <!-- <Galeria /> -->
  <Servicios />
  <Alcance />
  <Proceso />
  <Contacto />
</Layout>
