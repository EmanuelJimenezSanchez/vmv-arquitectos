---
interface Props {
  href?: string
  type?: 'button' | 'submit' | 'reset'
  variant?: 'primary' | 'glass' | 'outline' | 'white' | 'gray' | 'header'
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'xxl'
  class?: string
  shape?: 'rounded' | 'pill' | 'square'
  [attribute: string]: unknown
}

const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  class: className = '',
  shape = 'square',
  ...attributes
} = Astro.props as Props

const baseClass =
  'inline-flex items-center justify-center rounded-full border vmv-button-1 uppercase transition-[transform,background-color,color,border-color] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vmv-ring focus-visible:ring-offset-2 focus-visible:ring-offset-vmv-background'

const variantClasses = {
  primary:
    'border-vmv-primary bg-vmv-primary text-vmv-primary-foreground hover:bg-vmv-gray-11 hover:border-vmv-gray-11',
  glass:
    'border-vmv-sand-1/38 bg-vmv-sand-1/8 text-vmv-sand-1/92 tracking-[0.22em] hover:-translate-y-px',
  outline:
    'border-vmv-border bg-transparent text-vmv-foreground hover:bg-vmv-muted hover:border-vmv-gray-6',
  white: 'border-white bg-white text-black hover:text-white hover:bg-vmv-sand-1 hover:border-vmv-sand-1',
  gray: 'border-vmv-gray-9 bg-vmv-gray-9 text-white hover:bg-vmv-gray-10 hover:border-vmv-gray-10',
  header:
    'border-transparent bg-transparent text-vmv-sand-1 hover:text-vmv-sand-2 hover:bg-transparent tracking-[0.12em] px-0 py-0',
}

const sizeClasses = {
  sm: 'px-4 py-2.5',
  md: 'px-[1.3rem] py-[0.6rem] max-md:px-[0.92rem] max-md:text-[0.62rem] max-md:tracking-[0.18em]',
  lg: 'px-6 py-3 text-lg',
  xl: 'px-8 py-3.5 text-base tracking-[0.2em] max-md:px-6 max-md:py-3',
  xxl: 'px-10 py-4 text-lg tracking-[0.22em] max-md:px-7 max-md:py-3.5',
}

const shapeClasses = {
  rounded: 'rounded-lg',
  pill: 'rounded-full',
  square: 'rounded-none',
}

const classes = [
  baseClass,
  variantClasses[variant],
  sizeClasses[size],
  shapeClasses[shape],
  className,
]
  .filter(Boolean)
  .join(' ')
---

{
  href ? (
    <a href={href} class={classes} {...attributes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...attributes}>
      <slot />
    </button>
  )
}
