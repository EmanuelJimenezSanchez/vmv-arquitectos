---
const services = [
  {
    num: '01',
    title: 'Diseño Arquitectónico',
    desc: 'Personalización, ambientes únicos y auténticos acorde al gusto y necesidades del cliente.',
  },
  {
    num: '02',
    title: 'Asesoramiento de Construcción',
    desc: 'Tu proyecto arquitectónico de la mano de profesionales.',
  },
  {
    num: '03',
    title: 'Servicio Personalizado',
    desc: 'En cada una de las etapas del diseño, acompañándote de principio a fin.',
  },
];

// Paneles de la columna izquierda: en desktop (con motion) son capas
// absolutas que GSAP intercambia; en mobile o reduced-motion fluyen normal.
const panelClasses =
  'relative flex flex-col justify-center px-[clamp(1.5rem,6vw,3rem)] py-[clamp(3rem,7vw,5rem)] md:py-[clamp(3.5rem,8vw,7rem)] md:pr-[clamp(2rem,6vw,5rem)] md:pl-[clamp(2rem,9vw,8rem)] md:motion-safe:absolute md:motion-safe:inset-0';

const panelLabelClasses =
  'mb-[clamp(1.2rem,2.5vw,2rem)] block text-[clamp(0.58rem,1vw,0.7rem)] tracking-[0.3em] indent-[0.3em] uppercase text-vmv-sand-9';

const navDotClasses =
  'size-[5px] shrink-0 rounded-full border border-vmv-sand-9/40 bg-vmv-sand-9/22 transition-[background-color,border-color,scale] duration-[400ms] data-active:scale-[1.6] data-active:border-vmv-sand-12 data-active:bg-vmv-sand-12';
---

<section id="nosotros" class="relative">
  <!-- ─── HERO: CORTINA + FRASE ICÓNICA ──────────────── -->
  <div
    data-nosotros="hero"
    class="relative h-dvh overflow-hidden bg-vmv-gray-12 motion-reduce:hidden"
  >
    <div
      data-nosotros="panel-l"
      class="absolute top-0 left-0 h-full w-1/2 overflow-hidden after:pointer-events-none after:absolute after:inset-0 after:bg-linear-to-r after:from-[#0f0e0c]/10 after:to-[#0f0e0c]/55"
    >
      <img
        src="/images/nosotros/nosotros-1.webp"
        alt="Diseño arquitectónico VMV Arquitectos"
        class="block h-full w-full object-cover object-[40%_center]"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div
      data-nosotros="panel-r"
      class="absolute top-0 right-0 h-full w-1/2 overflow-hidden after:pointer-events-none after:absolute after:inset-0 after:bg-linear-to-l after:from-[#0f0e0c]/10 after:to-[#0f0e0c]/55"
    >
      <img
        src="/images/nosotros/nosotros-2.webp"
        alt="Construcción de lujo VMV Arquitectos"
        class="block h-full w-full object-cover object-[60%_center]"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div
      data-nosotros="label"
      class="pointer-events-none absolute top-1/2 left-1/2 z-10 flex -translate-x-1/2 -translate-y-1/2 flex-col items-center gap-[1.1rem] whitespace-nowrap"
      aria-hidden="true"
    >
      <div class="h-11 w-px bg-vmv-sand-1/50"></div>
      <span
        class="text-[clamp(2.25rem,7vw,5.5rem)] font-extralight tracking-[0.45em] indent-[0.45em] uppercase text-vmv-sand-1"
      >
        NOSOTROS
      </span>
      <div class="h-11 w-px bg-vmv-sand-1/50"></div>
    </div>

    <div
      data-nosotros="scroll-hint"
      class="absolute bottom-9 left-1/2 z-10 -translate-x-1/2"
      aria-hidden="true"
    >
      <span
        class="scroll-drop block h-14 w-px bg-linear-to-b from-vmv-sand-1/0 via-vmv-sand-1/65 to-vmv-sand-1/0"
      ></span>
    </div>

    <div
      data-nosotros="reveal"
      class="pointer-events-none absolute inset-0 z-10 flex items-center justify-center px-[clamp(2rem,9vw,7rem)]"
    >
      <p
        data-nosotros="reveal-text"
        class="max-w-3xl text-center text-[clamp(1.5rem,3.2vw,3rem)] font-extralight leading-normal tracking-[0.04em]"
      >
        Más de diez años convirtiendo visiones en espacios de lujo.
      </p>
    </div>
  </div>

  <!-- ─── ABOUT: PINNEADO ──────── -->
  <div
    data-nosotros="about"
    class="relative grid min-h-svh grid-cols-1 overflow-hidden bg-vmv-sand-1 md:h-svh md:grid-cols-[55fr_45fr]"
  >
    <!-- Columna izquierda -->
    <div data-nosotros="about-left" class="relative min-h-svh overflow-hidden">
      <!-- Panel 1: información de la empresa -->
      <div data-nosotros="panel-info" class={panelClasses}>
        <span class={panelLabelClasses}>Sobre nosotros</span>
        <h2
          class="mb-[clamp(1.2rem,2.5vw,2rem)] max-w-104 text-[clamp(1.45rem,2.8vw,2.5rem)] font-light tracking-[-0.01em] text-vmv-gray-12 leading-[1.25]"
        >
          Diseño, construcción y remodelación con más de 10&nbsp;años de
          experiencia.
        </h2>
        <p
          class="max-w-lg text-[clamp(0.875rem,1.25vw,0.975rem)] font-light tracking-[0.02em] text-vmv-gray-10 leading-[1.9]"
        >
          Somos un despacho de arquitectura especializado en el ramo del diseño,
          construcción y remodelación comercial y habitacional. Nos
          especializamos en la construcción de casas de lujo en las mejores
          zonas de la ciudad, creando ambientes únicos y auténticos acorde al
          gusto y necesidades de cada cliente.
        </p>
      </div>

      <!-- Panel 2: servicios (GSAP lo trae desde abajo) -->
      <div
        data-nosotros="panel-services"
        class={`${panelClasses} motion-reduce:hidden`}
      >
        <span class={panelLabelClasses}>Nuestros servicios</span>
        <ul class="border-t border-vmv-sand-6/28">
          {
            services.map((service) => (
              <li class="grid grid-cols-[clamp(2.5rem,6vw,4.5rem)_1fr] items-start gap-[clamp(1rem,3vw,2.5rem)] border-b border-vmv-sand-6/28 py-[clamp(1.2rem,2.5vw,1.8rem)] max-[480px]:grid-cols-1 max-[480px]:gap-[0.3rem]">
                <span
                  class="text-right text-[clamp(1.8rem,4vw,3.5rem)] font-thin tracking-[-0.02em] text-vmv-sand-9/30 leading-[0.9] max-[480px]:text-left max-[480px]:text-[1.6rem]"
                  aria-hidden="true"
                >
                  {service.num}
                </span>
                <div class="pt-1">
                  <h3 class="mb-[0.45rem] text-[clamp(0.85rem,1.6vw,1.15rem)] font-light tracking-[0.16em] uppercase text-vmv-gray-12">
                    {service.title}
                  </h3>
                  <p class="text-[clamp(0.8rem,1.15vw,0.88rem)] font-light tracking-[0.02em] text-vmv-gray-10 leading-[1.8]">
                    {service.desc}
                  </p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Columna derecha -->
    <div
      data-nosotros="about-right"
      class="relative h-[60vw] overflow-hidden md:h-auto"
    >
      <div data-nosotros="img-layer-1" class="absolute inset-0">
        <img
          src="/images/nosotros/nosotros-3.webp"
          alt="Proyecto VMV Arquitectos"
          class="block h-full w-full object-cover object-center"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div data-nosotros="img-layer-2" class="absolute inset-0">
        <img
          src="/images/nosotros/nosotros-4.webp"
          alt="Servicios VMV Arquitectos"
          class="block h-full w-full object-cover object-center"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <!-- Indicador de progreso lateral izquierdo -->
    <div
      class="pointer-events-none absolute top-1/2 left-[clamp(0.9rem,2.2vw,1.6rem)] z-20 flex -translate-y-1/2 flex-col items-center"
      aria-hidden="true"
    >
      <span data-nosotros="nav-dot-1" class={navDotClasses}></span>
      <div
        class="relative my-[9px] h-[clamp(2.5rem,4.5vw,3.75rem)] w-px overflow-hidden bg-vmv-sand-6/28"
      >
        <div
          data-nosotros="nav-fill"
          class="absolute top-0 left-0 h-0 w-full bg-vmv-sand-12"
        >
        </div>
      </div>
      <span data-nosotros="nav-dot-2" class={navDotClasses}></span>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';
  import { $ } from '@/lib/dom-selector';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const activeTriggers: ScrollTrigger[] = [];
  let revealSplit: SplitText | null = null;

  function killAll() {
    activeTriggers.forEach((t) => t.kill());
    activeTriggers.length = 0;
    revealSplit?.revert();
    revealSplit = null;
  }

  function initNosotros() {
    killAll();

    // ── HERO ─────────────────────────────────────────
    const hero        = $<HTMLElement>('[data-nosotros="hero"]');
    const panelL      = $<HTMLElement>('[data-nosotros="panel-l"]');
    const panelR      = $<HTMLElement>('[data-nosotros="panel-r"]');
    const label       = $<HTMLElement>('[data-nosotros="label"]');
    const scrollHint  = $<HTMLElement>('[data-nosotros="scroll-hint"]');
    const revealEl    = $<HTMLElement>('[data-nosotros="reveal"]');
    const revealText  = $<HTMLParagraphElement>('[data-nosotros="reveal-text"]');

    if (!hero || !panelL || !panelR || !label || !revealEl || !revealText) return;

    // Word-spans
    revealSplit = SplitText.create(revealText, { type: 'words', aria: 'auto' });

    gsap.set(revealEl, { opacity: 0 });
    gsap.set(revealSplit.words, { color: 'rgba(255,255,255,0.15)' });

    const heroTl = gsap.timeline({
      scrollTrigger: {
        trigger: hero,
        start: 'top top',
        end: '+=260%',
        scrub: 1,
        pin: true,
        anticipatePin: 1,
      },
    });

    heroTl
      .to([label, scrollHint], { opacity: 0, y: -10, duration: 0.3, ease: 'power2.in' }, 0)
      .to(panelL, { xPercent: -100, ease: 'power2.inOut', duration: 1 }, 0.18)
      .to(panelR, { xPercent: 100, ease: 'power2.inOut', duration: 1 }, 0.18)
      .to(revealEl, { opacity: 1, duration: 0.35, ease: 'power2.out' }, 1.2)
      .to(
        revealSplit.words,
        { color: 'rgba(255,255,255,0.92)', stagger: { each: 0.12 }, duration: 0.12, ease: 'none' },
        1.55,
      )

    const heroSt = heroTl.scrollTrigger;
    if (heroSt) activeTriggers.push(heroSt);

    // ── ABOUT (solo en pantallas grandes) ────────────
    const isDesktop = window.matchMedia('(min-width: 768px)').matches;
    const isPrefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (isDesktop && !isPrefersReducedMotion) {
      const aboutSection  = $<HTMLElement>('[data-nosotros="about"]');
      const aboutLeft     = $<HTMLElement>('[data-nosotros="about-left"]');
      const aboutRight    = $<HTMLElement>('[data-nosotros="about-right"]');
      const infoPanel     = $<HTMLElement>('[data-nosotros="panel-info"]');
      const servicesPanel = $<HTMLElement>('[data-nosotros="panel-services"]');
      const imgLayer1     = $<HTMLElement>('[data-nosotros="img-layer-1"]');
      const imgLayer2     = $<HTMLElement>('[data-nosotros="img-layer-2"]');
      const navDot1       = $<HTMLElement>('[data-nosotros="nav-dot-1"]');
      const navDot2       = $<HTMLElement>('[data-nosotros="nav-dot-2"]');
      const navFill       = $<HTMLElement>('[data-nosotros="nav-fill"]');

      if (
        !aboutSection || !aboutLeft || !aboutRight ||
        !infoPanel || !servicesPanel || !imgLayer1 || !imgLayer2
      ) return;

      // Estado inicial
      gsap.set(aboutLeft,     { x: -60, opacity: 0 });
      gsap.set(aboutRight,    { x: 60, opacity: 0, scale: 1.05 });
      gsap.set(servicesPanel, { yPercent: 100 });
      gsap.set(imgLayer2,     { opacity: 0 });

      // Nav: dot 1 activo al inicio
      navDot1?.setAttribute('data-active', '');

      // Fase 0: Entrada cuando el about entra al viewport (antes del pin)
      activeTriggers.push(
        ScrollTrigger.create({
          trigger: aboutSection,
          start: 'top 78%',
          once: true,
          onEnter: () => {
            gsap.to(aboutLeft,  { x: 0, opacity: 1, duration: 1.1, ease: 'power3.out' });
            gsap.to(aboutRight, { x: 0, opacity: 1, scale: 1, duration: 1.3, ease: 'power3.out', delay: 0.08 });
          },
        }),
      );

      // Fase 1→2: Pin + swap de contenido al hacer scroll
      const aboutTl = gsap.timeline({
        scrollTrigger: {
          trigger: aboutSection,
          start: 'top top',
          end: '+=300%',
          scrub: 1,
          pin: true,
          anticipatePin: 1,
          onUpdate: (self) => {
            const p = self.progress;
            // Relleno del track proporcional al progreso del scroll
            if (navFill) navFill.style.height = `${p * 100}%`;
            // Cambio de dot activo cuando el swap de paneles ocurre
            // (~0.52 del timeline / 1.35 de total ≈ 40% del scroll)
            const inPhase2 = p > 0.4;
            navDot1?.toggleAttribute('data-active', !inPhase2);
            navDot2?.toggleAttribute('data-active', inPhase2);
          },
        },
      });

      aboutTl
        .to(infoPanel,     { yPercent: -100, opacity: 0, duration: 0.38, ease: 'power2.in' }, 0.38)
        .to(imgLayer1,     { opacity: 0, duration: 0.32, ease: 'power2.inOut' },              0.42)
        .to(servicesPanel, { yPercent: 0, duration: 0.44, ease: 'power3.out' },               0.56)
        .to(imgLayer2,     { opacity: 1, duration: 0.38, ease: 'power2.inOut' },              0.54)

      const aboutSt = aboutTl.scrollTrigger;
      if (aboutSt) activeTriggers.push(aboutSt);
    }
  }

  document.addEventListener('astro:before-swap', killAll);
  document.addEventListener('astro:page-load', initNosotros);
  initNosotros();
</script>

<style>
  .scroll-drop {
    animation: scroll-drop 2.2s ease-in-out infinite;
  }

  @keyframes scroll-drop {
    0% {
      transform: translateY(-40%) scaleY(0.5);
      opacity: 0;
    }
    40% {
      opacity: 1;
    }
    100% {
      transform: translateY(40%) scaleY(0.5);
      opacity: 0;
    }
  }
</style>
