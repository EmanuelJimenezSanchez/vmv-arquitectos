---
---

<section id="nosotros" class="nosotros">
  <div class="nosotros__hero">
    <div class="nosotros__panel nosotros__panel--l">
      <img
        src="/images/nosotros/nosotros-1.webp"
        alt="Diseño arquitectónico VMV Arquitectos"
        class="nosotros__img nosotros__img--l"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="nosotros__panel nosotros__panel--r">
      <img
        src="/images/nosotros/nosotros-2.webp"
        alt="Construcción de lujo VMV Arquitectos"
        class="nosotros__img nosotros__img--r"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="nosotros__label" aria-hidden="true">
      <div class="nosotros__label-rule"></div>
      <span class="nosotros__label-text">NOSOTROS</span>
      <div class="nosotros__label-rule"></div>
    </div>

    <div class="nosotros__scroll-hint" aria-hidden="true">
      <span class="nosotros__scroll-line"></span>
    </div>
  </div>

  <!-- ─── CONTENIDO ──────────────────────────────────── -->
  <div class="nosotros__content">
    <!-- Declaración editorial -->
    <div class="nosotros__statement">
      <p class="nosotros__statement-copy">
        Somos un despacho de arquitectura con más de
        <strong class="nosotros__statement-accent">10&nbsp;años</strong>
        de experiencia en el ramo del diseño, construcción y remodelación
        comercial y habitacional. Nos especializamos en la construcción de
        casas de lujo en las mejores zonas de la ciudad.
      </p>
    </div>

    <!-- Pilares de servicio -->
    <ul class="nosotros__pillars" aria-label="Nuestros servicios">
      <li class="nosotros__pillar">
        <span class="nosotros__pillar-num" aria-hidden="true">01</span>
        <div class="nosotros__pillar-body">
          <h3 class="nosotros__pillar-title">Diseño Arquitectónico</h3>
          <p class="nosotros__pillar-desc">
            Personalización, ambientes únicos y auténticos acorde al gusto y
            necesidades del cliente.
          </p>
        </div>
      </li>
      <li class="nosotros__pillar">
        <span class="nosotros__pillar-num" aria-hidden="true">02</span>
        <div class="nosotros__pillar-body">
          <h3 class="nosotros__pillar-title">Asesoramiento de Construcción</h3>
          <p class="nosotros__pillar-desc">
            Tu proyecto arquitectónico de la mano de profesionales.
          </p>
        </div>
      </li>
      <li class="nosotros__pillar">
        <span class="nosotros__pillar-num" aria-hidden="true">03</span>
        <div class="nosotros__pillar-body">
          <h3 class="nosotros__pillar-title">Servicio Personalizado</h3>
          <p class="nosotros__pillar-desc">
            En cada una de las etapas del diseño, acompañándote de principio
            a fin.
          </p>
        </div>
      </li>
    </ul>

    <p class="nosotros__tagline" aria-hidden="true">VMV&nbsp;ARQUITECTOS</p>
  </div>
</section>

<style>
  /* ── ROOT ─────────────────────────────────────────── */
  .nosotros {
    position: relative;
  }

  /* ── HERO ─────────────────────────────────────────── */
  .nosotros__hero {
    position: relative;
    height: 100svh;
    background: var(--vmv-gray-12);
    overflow: hidden;
  }

  .nosotros__panel {
    position: absolute;
    top: 0;
    width: 50%;
    height: 100%;
    overflow: hidden;
  }

  .nosotros__panel--l {
    left: 0;
  }

  .nosotros__panel--r {
    right: 0;
  }

  .nosotros__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .nosotros__img--l {
    object-position: 40% center;
  }

  .nosotros__img--r {
    object-position: 60% center;
  }

  /* Gradiente hacia el centro para legibilidad del label */
  .nosotros__panel--l::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15, 14, 12, 0.1) 0%,
      rgba(15, 14, 12, 0.55) 100%
    );
    pointer-events: none;
  }

  .nosotros__panel--r::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to left,
      rgba(15, 14, 12, 0.1) 0%,
      rgba(15, 14, 12, 0.55) 100%
    );
    pointer-events: none;
  }

  /* ── LABEL CENTRAL ─────────────────────────────────── */
  .nosotros__label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
    white-space: nowrap;
    pointer-events: none;
  }

  .nosotros__label-rule {
    width: 1px;
    height: 2.75rem;
    background: color-mix(in srgb, var(--vmv-sand-1) 50%, transparent);
  }

  .nosotros__label-text {
    font-size: clamp(2.25rem, 7vw, 5.5rem);
    font-weight: 200;
    letter-spacing: 0.45em;
    text-indent: 0.45em;
    color: var(--vmv-sand-1);
    text-transform: uppercase;
  }

  /* ── SCROLL HINT ───────────────────────────────────── */
  .nosotros__scroll-hint {
    position: absolute;
    bottom: 2.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
  }

  .nosotros__scroll-line {
    display: block;
    width: 1px;
    height: 3.5rem;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--vmv-sand-1) 0%, transparent) 0%,
      color-mix(in srgb, var(--vmv-sand-1) 65%, transparent) 50%,
      color-mix(in srgb, var(--vmv-sand-1) 0%, transparent) 100%
    );
    animation: nosotrosScrollDrop 2.2s ease-in-out infinite;
  }

  @keyframes nosotrosScrollDrop {
    0% {
      transform: translateY(-40%) scaleY(0.5);
      opacity: 0;
    }
    40% {
      opacity: 1;
    }
    100% {
      transform: translateY(40%) scaleY(0.5);
      opacity: 0;
    }
  }

  /* ── CONTENIDO ─────────────────────────────────────── */
  .nosotros__content {
    background: var(--vmv-gray-12);
    color: var(--vmv-sand-1);
    padding: clamp(5rem, 12vw, 10rem) clamp(1.5rem, 8vw, 9rem)
      clamp(5rem, 10vw, 9rem);
  }

  /* ── DECLARACIÓN ───────────────────────────────────── */
  .nosotros__statement {
    max-width: 52rem;
    margin: 0 auto clamp(5rem, 12vw, 9rem);
    text-align: center;
  }

  .nosotros__statement-copy {
    font-size: clamp(1.1rem, 2.2vw, 1.75rem);
    font-weight: 300;
    line-height: 1.8;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--vmv-sand-2) 78%, transparent);
    margin: 0;
  }

  .nosotros__statement-accent {
    font-weight: 500;
    font-style: normal;
    color: var(--vmv-sand-7);
  }

  /* ── PILARES ───────────────────────────────────────── */
  .nosotros__pillars {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid color-mix(in srgb, var(--vmv-gray-7) 22%, transparent);
  }

  .nosotros__pillar {
    display: grid;
    grid-template-columns: clamp(3rem, 10vw, 7rem) 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
    padding: clamp(2rem, 5vw, 3.5rem) 0;
    border-bottom: 1px solid
      color-mix(in srgb, var(--vmv-gray-7) 22%, transparent);
  }

  .nosotros__pillar-num {
    font-size: clamp(2.5rem, 8vw, 6.5rem);
    font-weight: 100;
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: color-mix(in srgb, var(--vmv-sand-9) 32%, transparent);
    text-align: right;
  }

  .nosotros__pillar-body {
    padding-top: 0.3rem;
  }

  .nosotros__pillar-title {
    font-size: clamp(1.05rem, 2.5vw, 1.75rem);
    font-weight: 300;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--vmv-sand-1);
    margin: 0 0 0.65rem;
  }

  .nosotros__pillar-desc {
    font-size: clamp(0.875rem, 1.4vw, 1.05rem);
    font-weight: 300;
    line-height: 1.8;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--vmv-sand-6) 82%, transparent);
    margin: 0;
    max-width: 40rem;
  }

  /* ── TAGLINE ───────────────────────────────────────── */
  .nosotros__tagline {
    margin: clamp(4rem, 10vw, 7rem) 0 0;
    font-size: clamp(0.6rem, 1.8vw, 0.9rem);
    font-weight: 200;
    letter-spacing: 0.65em;
    text-indent: 0.65em;
    text-transform: uppercase;
    text-align: center;
    color: color-mix(in srgb, var(--vmv-sand-8) 28%, transparent);
  }

  /* ── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 480px) {
    .nosotros__pillar {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }

    .nosotros__pillar-num {
      font-size: 2rem;
      text-align: left;
    }

    .nosotros__pillar-body {
      padding-top: 0;
    }
  }

  /* ── MOTION REDUCIDO ───────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .nosotros__hero {
      display: none;
    }

    .nosotros__scroll-line {
      animation: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { $, $$ } from '@/lib/dom-selector';

  gsap.registerPlugin(ScrollTrigger);

  const activeTriggers: ScrollTrigger[] = [];

  function killAll() {
    activeTriggers.forEach((t) => t.kill());
    activeTriggers.length = 0;
  }

  function initNosotros() {
    killAll();

    const hero = $<HTMLElement>('.nosotros__hero');
    const panelL = $<HTMLElement>('.nosotros__panel--l');
    const panelR = $<HTMLElement>('.nosotros__panel--r');
    const label = $<HTMLElement>('.nosotros__label');
    const scrollHint = $<HTMLElement>('.nosotros__scroll-hint');

    if (!hero || !panelL || !panelR || !label) return;

    // ── 1. CORTINA (pinned scrub) ──────────────────────
    const splitTl = gsap.timeline({
      scrollTrigger: {
        trigger: hero,
        start: 'top top',
        end: '+=110%',
        scrub: 1.5,
        pin: true,
        anticipatePin: 1,
      },
    });

    splitTl
      .to(
        [label, scrollHint],
        { opacity: 0, y: -10, duration: 0.3, ease: 'power2.in' },
        0,
      )
      .to(panelL, { xPercent: -100, ease: 'power2.inOut', duration: 1 }, 0.18)
      .to(panelR, { xPercent: 100, ease: 'power2.inOut', duration: 1 }, 0.18);

    const splitSt = splitTl.scrollTrigger;
    if (splitSt) activeTriggers.push(splitSt);

    // ── 2. DECLARACIÓN ────────────────────────────────
    const statement = $<HTMLElement>('.nosotros__statement');
    if (statement) {
      gsap.set(statement, { opacity: 0, y: 40 });
      activeTriggers.push(
        ScrollTrigger.create({
          trigger: statement,
          start: 'top 80%',
          once: true,
          onEnter: () =>
            gsap.to(statement, {
              opacity: 1,
              y: 0,
              duration: 1.1,
              ease: 'power3.out',
            }),
        }),
      );
    }

    // ── 3. PILARES STAGGER ────────────────────────────
    const pillars = $$<HTMLElement>('.nosotros__pillar');
    if (pillars.length) {
      const nums = $$<HTMLElement>('.nosotros__pillar-num');
      gsap.set(pillars, { opacity: 0, y: 52 });
      gsap.set(nums, { x: -24, opacity: 0 });

      activeTriggers.push(
        ScrollTrigger.create({
          trigger: pillars[0]!,
          start: 'top 84%',
          once: true,
          onEnter: () => {
            gsap.to(pillars, {
              opacity: 1,
              y: 0,
              duration: 0.9,
              stagger: 0.15,
              ease: 'power3.out',
            });
            gsap.to(nums, {
              x: 0,
              opacity: 1,
              duration: 1.1,
              stagger: 0.15,
              delay: 0.08,
              ease: 'power3.out',
            });
          },
        }),
      );
    }

    // ── 4. TAGLINE ────────────────────────────────────
    const tagline = $<HTMLElement>('.nosotros__tagline');
    if (tagline) {
      gsap.set(tagline, { opacity: 0 });
      activeTriggers.push(
        ScrollTrigger.create({
          trigger: tagline,
          start: 'top 92%',
          once: true,
          onEnter: () =>
            gsap.to(tagline, { opacity: 1, duration: 1.6, ease: 'power2.out' }),
        }),
      );
    }
  }

  document.addEventListener('astro:before-swap', killAll);
  document.addEventListener('astro:page-load', initNosotros);
  initNosotros();
</script>
