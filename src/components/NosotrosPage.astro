---
import { galeria } from '@/data/galeria'
import Button from '@/components/ui/Button.astro'

---

<section id="nosotros" class="relative">
  <!-- ─── HERO: CORTINA + FRASE ICÓNICA ──────────────── -->
  <div
    data-nosotros="hero"
    class="relative h-dvh overflow-hidden bg-vmv-gray-1 motion-reduce:hidden"
  >
    <div
      data-nosotros="panel-l"
      class="absolute top-0 left-0 h-full w-1/2 overflow-hidden after:pointer-events-none after:absolute after:inset-0 after:bg-linear-to-r after:from-[#0f0e0c]/10 after:to-[#0f0e0c]/55"
    >
      <img
        src="/images/nosotros/nosotros-1.webp"
        alt="Diseño arquitectónico VMV Arquitectos"
        class="block h-full w-full object-cover object-[40%_center]"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div
      data-nosotros="panel-r"
      class="absolute top-0 right-0 h-full w-1/2 overflow-hidden after:pointer-events-none after:absolute after:inset-0 after:bg-linear-to-l after:from-[#0f0e0c]/10 after:to-[#0f0e0c]/55"
    >
      <img
        src="/images/nosotros/nosotros-2.webp"
        alt="Construcción de lujo VMV Arquitectos"
        class="block h-full w-full object-cover object-[60%_center]"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div
      data-nosotros="label"
      class="pointer-events-none absolute top-1/2 left-1/2 z-10 flex -translate-x-1/2 -translate-y-1/2 flex-col items-center gap-[1.1rem] whitespace-nowrap"
    >
      <div class="h-11 w-px bg-vmv-sand-1/50" aria-hidden="true"></div>
      <span class="vmv-title-1 text-white"> NOSOTROS </span>
      <div class="h-11 w-px bg-vmv-sand-1/50" aria-hidden="true"></div>
      <!-- <div data-nosotros="label-cta" class="pointer-events-auto mt-[0.6rem]">
        <Button href="/#contacto" variant="white" size="lg">Contacta a un arquitecto</Button>
      </div> -->
    </div>

    <div
      data-nosotros="scroll-hint"
      class="absolute bottom-9 left-1/2 z-10 -translate-x-1/2"
      aria-hidden="true"
    >
      <span
        class="scroll-drop block h-14 w-px bg-linear-to-b from-vmv-sand-1/0 via-vmv-sand-1/65 to-vmv-sand-1/0"
      ></span>
    </div>

    <div
      data-nosotros="galeria-media"
      class="pointer-events-none absolute top-1/2 left-1/2 z-6 -translate-x-1/2 -translate-y-1/2 overflow-hidden opacity-0"
      aria-hidden="true"
    >
      <div class="relative h-full w-full">
        {
          galeria.map((item, index) => (
            <img
              src={item.image}
              alt={item.description}
              class={`absolute inset-0 block h-full w-full object-cover ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
              data-nosotros="galeria-image"
              loading="lazy"
              decoding="async"
            />
          ))
        }
      </div>
    </div>

    <div
      data-nosotros="galeria-copy"
      class="pointer-events-none absolute inset-0 z-7 flex flex-col items-center justify-center gap-[0.08em] px-[clamp(1rem,4vw,3rem)] text-center opacity-0"
    >
      <!-- <p
        data-nosotros="galeria-main"
        class="vmv-title-1 mx-auto max-w-[24ch] text-balance text-vmv-sand-1 [text-shadow:0_14px_30px_rgba(0,0,0,0.35)]"
      >
        Convertimos tu visión en el espacio de lujo que siempre soñaste.
      </p> -->
      <div data-nosotros="galeria-cta" class="pointer-events-auto mt-[clamp(1.5rem,3vw,2.5rem)]">
        <Button href="/#contacto" variant="white" size="xxl">Contacta a un arquitecto</Button>
      </div>
    </div>

    <div
      data-nosotros="reveal"
      class="pointer-events-none absolute inset-0 z-10 flex flex-col items-center justify-center px-[clamp(2rem,9vw,7rem)]"
    >
      <p data-nosotros="reveal-text" class="vmv-title-2 max-w-3xl text-center text-vmv-gray-12">
        Más de diez años convirtiendo visiones en espacios de lujo.
      </p>
      <!-- <div data-nosotros="reveal-cta" class="pointer-events-auto mt-[clamp(1.5rem,3vw,2.5rem)]">
        <Button href="/#contacto" variant="white" size="xl">Ponte en contacto</Button>
      </div> -->
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { SplitText } from 'gsap/SplitText'
  import { $, $$ } from '@/lib/dom-selector'
  // import { Observer } from 'gsap/Observer'

  gsap.registerPlugin(ScrollTrigger, SplitText)

  const activeTriggers: ScrollTrigger[] = []
  let revealSplit: SplitText | null = null

  // const observer = Observer.create({
  //   preventDefault: true,
  //   type: 'wheel,touch,pointer',
  //   // enabled: false,
  // })

  function killAll() {
    activeTriggers.forEach((t) => t.kill())
    activeTriggers.length = 0
    revealSplit?.revert()
    revealSplit = null
  }

  // function lockScroll() {
  //   observer.enable()
  // }

  // function unlockScroll() {
  //   observer.disable()
  // }

  function initNosotros() {
    killAll()

    // ── HERO ─────────────────────────────────────────
    const hero = $<HTMLElement>('[data-nosotros="hero"]')
    const panelL = $<HTMLElement>('[data-nosotros="panel-l"]')
    const panelR = $<HTMLElement>('[data-nosotros="panel-r"]')
    const label = $<HTMLElement>('[data-nosotros="label"]')
    const scrollHint = $<HTMLElement>('[data-nosotros="scroll-hint"]')
    const revealEl = $<HTMLElement>('[data-nosotros="reveal"]')
    const revealText = $<HTMLParagraphElement>('[data-nosotros="reveal-text"]')
    // const revealImgs  = $$<HTMLElement>('[data-nosotros="reveal-img"]');
    const galeriaMedia = $<HTMLElement>('[data-nosotros="galeria-media"]')
    const galeriaImages = $$<HTMLElement>('[data-nosotros="galeria-image"]')
    const galeriaCopy = $<HTMLElement>('[data-nosotros="galeria-copy"]')
    // const galeriaMain = $<HTMLParagraphElement>('[data-nosotros="galeria-main"]')
    const galeriaCta = $<HTMLElement>('[data-nosotros="galeria-cta"]')

    if (!hero || !panelL || !panelR || !label || !revealEl || !revealText) return

    // Word-spans
    revealSplit = SplitText.create(revealText, { type: 'words', aria: 'auto' })

    gsap.set(revealEl, { opacity: 0 })
    gsap.set(revealSplit.words, { opacity: 0.5 })
    // gsap.set(revealImgs, { opacity: 0, scale: 0.85 });

    const hasGaleriaCopy = galeriaCopy && galeriaCta

    if (hasGaleriaCopy) {
      gsap.set(galeriaCopy, { opacity: 0 })
      // gsap.set(galeriaMain, { opacity: 0, y: 10 })
      gsap.set(galeriaCta, { opacity: 0, y: 20 })
    }

    if (galeriaMedia) {
      gsap.set(galeriaMedia, {
        width: '16rem',
        height: '16rem',
        borderRadius: '999px',
        opacity: 0,
      })
      gsap.set(galeriaImages, { opacity: 0 })
      if (galeriaImages[0]) gsap.set(galeriaImages[0], { opacity: 1 })
    }

    const heroTl = gsap.timeline({
      paused: true,
    })

    heroTl.to([label, scrollHint], {
      opacity: 0,
      y: -50,
      duration: 0.6,
      ease: 'power2.in',
      delay: 0.1,
    })
    .to(panelL, { xPercent: -100, ease: 'power2.inOut', duration: 1.4 }, '<')
    .to(panelR, { xPercent: 100, ease: 'power2.inOut', duration: 1.4 }, '<')
    .to(revealEl, { opacity: 1, duration: 0.35, ease: 'power2.out' }, 1)
    .to(revealSplit.words, {
      // color: 'rgba(255,255,255,0.92)',
      opacity: 1,
      stagger: { each: 0.08 },
      duration: 0.08,
      ease: 'none',
    })
    .to(galeriaMedia, { opacity: 1, duration: 1, ease: 'none', delay: 0.3 }, '<')

    if (galeriaMedia && galeriaImages.length > 0) {
      heroTl.addLabel('galeriaReveal')

      const scaleStartOffset = 0.5
      const scaleDuration = 2
      const imageSwapStart = scaleStartOffset + 0.1
      const imageSwapDuration = 0.03

      heroTl.to(
          revealEl,
          { opacity: 0, scale: 0.95, duration: 0.4, ease: 'power2.in' },
          'galeriaReveal',
        )
        .to(
          galeriaMedia,
          {
            width: '100vw',
            height: '100vh',
            borderRadius: '0px',
            duration: scaleDuration,
            ease: 'none',
          },
          `galeriaReveal+=${scaleStartOffset}`,
        )

      let imageCycleEnd = scaleStartOffset + scaleDuration
      const swapCount = galeriaImages.length - 1
      if (swapCount > 0) {
        const swapSpacing =
          swapCount > 1 ? (scaleDuration - 0.3 - imageSwapDuration) / (swapCount - 1) : 0

        galeriaImages.slice(1).forEach((image, i) => {
          const previousImage = galeriaImages[i]
          const swapTime = imageSwapStart + i * swapSpacing

          heroTl
            .to(
              previousImage,
              { opacity: 0, duration: imageSwapDuration, ease: 'none' },
              `galeriaReveal+=${swapTime}`,
            )
            .to(image, { opacity: 1, duration: imageSwapDuration, ease: 'none' }, '<')
        })
      }

      // Frase de conversión y botón de contacto: el mismo remate que tiene
      // Galeria.astro al final de su animación, ahora aparece cuando el
      // ciclo de imágenes de la galería termina.
      if (hasGaleriaCopy) {
        heroTl.addLabel('galeriaCopyReveal', `galeriaReveal+=${imageCycleEnd + 0.2}`)

        heroTl
          .to(galeriaCopy, { opacity: 1, duration: 0.4, ease: 'power2.out' }, 'galeriaCopyReveal')
          // .to(
          //   galeriaMain,
          //   { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' },
          //   'galeriaCopyReveal',
          // )
          .to(
            galeriaCta,
            { opacity: 1, y: 0, duration: 0.3, ease: 'power2.out' },
            'galeriaCopyReveal+=0.4',
          )
      }
    }

    const heroSt = ScrollTrigger.create({
      trigger: hero,
      start: 'top 05%',
      onEnter: () => heroTl.play(),
      // onEnter: async () => {
      //   lockScroll();
      //   await heroTl.play();
      //   unlockScroll();
      // },
      // onLeaveBack: () => {
      //   heroTl.pause(0);
      // },
    })

    activeTriggers.push(heroSt)

    // ── ABOUT (solo en pantallas grandes) ────────────
    const isDesktop = window.matchMedia('(min-width: 768px)').matches
    const isPrefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (isDesktop && !isPrefersReducedMotion) {
      const aboutSection = $<HTMLElement>('[data-nosotros="about"]')
      const aboutLeft = $<HTMLElement>('[data-nosotros="about-left"]')
      const aboutRight = $<HTMLElement>('[data-nosotros="about-right"]')
      const infoPanel = $<HTMLElement>('[data-nosotros="panel-info"]')
      const servicesPanel = $<HTMLElement>('[data-nosotros="panel-services"]')
      const imgLayer1 = $<HTMLElement>('[data-nosotros="img-layer-1"]')
      const imgLayer2 = $<HTMLElement>('[data-nosotros="img-layer-2"]')
      const navDot1 = $<HTMLElement>('[data-nosotros="nav-dot-1"]')
      const navDot2 = $<HTMLElement>('[data-nosotros="nav-dot-2"]')
      const navFill = $<HTMLElement>('[data-nosotros="nav-fill"]')

      if (
        !aboutSection ||
        !aboutLeft ||
        !aboutRight ||
        !infoPanel ||
        !servicesPanel ||
        !imgLayer1 ||
        !imgLayer2
      )
        return

      // Estado inicial
      gsap.set(aboutLeft, { x: -60, opacity: 0 })
      gsap.set(aboutRight, { x: 60, opacity: 0, scale: 1.05 })
      gsap.set(servicesPanel, { yPercent: 100 })
      gsap.set(imgLayer2, { opacity: 0 })

      // Nav: dot 1 activo al inicio
      navDot1?.setAttribute('data-active', '')

      // Fase 0: Entrada cuando el about entra al viewport (antes del pin)
      activeTriggers.push(
        ScrollTrigger.create({
          trigger: aboutSection,
          start: 'top 78%',
          once: true,
          onEnter: () => {
            gsap.to(aboutLeft, { x: 0, opacity: 1, duration: 1.1, ease: 'power3.out' })
            gsap.to(aboutRight, {
              x: 0,
              opacity: 1,
              scale: 1,
              duration: 1.3,
              ease: 'power3.out',
              delay: 0.08,
            })
          },
        }),
      )

      // Fase 1→2: Pin + swap de contenido al hacer scroll
      const aboutTl = gsap.timeline({
        scrollTrigger: {
          trigger: aboutSection,
          start: 'top top',
          end: '+=300%',
          scrub: 1,
          pin: true,
          anticipatePin: 1,
          onUpdate: (self) => {
            const p = self.progress
            // Relleno del track proporcional al progreso del scroll
            if (navFill) navFill.style.height = `${p * 100}%`
            // Cambio de dot activo cuando el swap de paneles ocurre
            // (~0.52 del timeline / 1.35 de total ≈ 40% del scroll)
            const inPhase2 = p > 0.4
            navDot1?.toggleAttribute('data-active', !inPhase2)
            navDot2?.toggleAttribute('data-active', inPhase2)
          },
        },
      })

      aboutTl
        .to(infoPanel, { yPercent: -100, opacity: 0, duration: 0.38, ease: 'power2.in' }, 0.38)
        .to(imgLayer1, { opacity: 0, duration: 0.32, ease: 'power2.inOut' }, 0.42)
        .to(servicesPanel, { yPercent: 0, duration: 0.44, ease: 'power3.out' }, 0.56)
        .to(imgLayer2, { opacity: 1, duration: 0.38, ease: 'power2.inOut' }, 0.54)

      const aboutSt = aboutTl.scrollTrigger
      if (aboutSt) activeTriggers.push(aboutSt)
    }
  }

  document.addEventListener('astro:before-swap', killAll)
  document.addEventListener('astro:page-load', initNosotros)
  initNosotros()
</script>

<style>
  .scroll-drop {
    animation: scroll-drop 2.2s ease-in-out infinite;
  }

  @keyframes scroll-drop {
    0% {
      transform: translateY(-40%) scaleY(0.5);
      opacity: 0;
    }
    40% {
      opacity: 1;
    }
    100% {
      transform: translateY(40%) scaleY(0.5);
      opacity: 0;
    }
  }
</style>
